{
  "name": "mesa-rol-client",
  "version": "4.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder build --win --x64"
  },
  "build": {
    "appId": "com.mesarol.app",
    "productName": "Mesa de Rol",
    "directories": { "output": "../release" },
    "win": { "target": "nsis", "icon": "src/icon.ico" },
    "nsis": { "oneClick": false, "allowToChangeInstallationDirectory": true },
    "files": ["main.js", "src/**/*"]
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0"
  }
}
